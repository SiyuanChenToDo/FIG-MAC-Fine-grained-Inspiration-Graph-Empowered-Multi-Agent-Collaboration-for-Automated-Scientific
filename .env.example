# =============================================================================
# VriSci-v2 Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values

# =============================================================================
# API Configuration (Required)
# =============================================================================

# Qwen API Key - Required for LLM access
QWEN_API_KEY=your-api-key-here

# Qwen API Base URL (optional, for custom endpoints)
QWEN_BASE_URL=https://api.qwen.com

# =============================================================================
# Model Configuration
# =============================================================================

# Model timeout in seconds (default: 1200 = 20 minutes)
CAMEL_MODEL_TIMEOUT=1200

# Context token limit (default: 40000)
CAMEL_CONTEXT_TOKEN_LIMIT=40000

# Agent-specific task timeout (optional)
AGENT_TASK_TIMEOUT=900

# =============================================================================
# RAG Configuration
# =============================================================================

# Disable vector retrieval (set to "1" or "true" to disable)
DISABLE_VECTOR_RETRIEVAL=false

# Disable graph retrieval (set to "1" or "true" to disable)
DISABLE_GRAPH_RETRIEVAL=false

# Vector database path (default: Myexamples/vdb/camel_faiss_storage)
VDB_PATH=Myexamples/vdb/camel_faiss_storage

# Knowledge graph JSON path (default: Myexamples/data/final_custom_kg_papers.json)
KG_PATH=Myexamples/data/final_custom_kg_papers.json

# =============================================================================
# Workflow Configuration
# =============================================================================

# Maximum iteration rounds (default: 3)
MAX_ITERATIONS=3

# Quality threshold 1-10 (default: 8.0)
QUALITY_THRESHOLD=8.0

# Polish iteration rounds (default: 1)
POLISH_ITERATIONS=1

# =============================================================================
# Output Configuration
# =============================================================================

# Output directory for reports (default: Scientific_Hypothesis_Reports)
OUTPUT_DIR=Scientific_Hypothesis_Reports

# Enable debug mode (set to "1" or "true" to enable)
DEBUG_MODE=false

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Log file path (optional)
LOG_FILE=logs/vrisci.log

# =============================================================================
# Performance Configuration
# =============================================================================

# Number of parallel workers for analysis phase (default: 3)
PARALLEL_WORKERS=3

# Memory token limit for workflow context (default: 40000)
WORKFLOW_TOKEN_LIMIT=40000
